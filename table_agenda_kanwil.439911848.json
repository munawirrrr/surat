	"eventHandlers": [
		{
			"eventId": "EVENT_AFTERADD",
			"pageType": "add",
			"code": "// Ambil nilai dari record yang baru ditambahkan\n$nomor_agenda = $values[\"nomor agenda\"];\n$tahun = $values[\"tahun\"];\n$nsm_list = str_replace(' ', '', $values[\"nsm\"]); // hilangkan spasi jika ada\n\n// Pecah nsm_list menjadi array\n$nsm_array = explode(\",\", $nsm_list);\n\n// Buat string untuk kondisi WHERE IN\n$nsm_in_clause = \"'\" . implode(\"','\", $nsm_array) . \"'\";\n\n// Bangun query UPDATE\n$sql = \"\n    UPDATE daftar \n    SET no_agenda_kanwil = '\" . db_addslashes($nomor_agenda) . \"', \n        status = 'diajukan ke kanwil' \n    WHERE tahun = '\" . db_addslashes($tahun) . \"'\n      AND nsm IN (\" . $nsm_in_clause . \")\n\";\n\n// Eksekusi query\nDB::Exec($sql);\n\n\n// Place event code here.\n// Use \"Add Action\" button to add code snippets."
		},
		{
			"eventId": "EVENT_AFTERDELETE",
			"pageType": "list",
			"code": "// Ambil nilai dari record yang dihapus\n$tahun = $deleted_values[\"tahun\"];\n$nsm_list = str_replace(' ', '', $deleted_values[\"nsm\"]); // hilangkan spasi jika ada\n\n// Pecah nsm_list menjadi array\n$nsm_array = explode(\",\", $nsm_list);\n\n// Buat string untuk kondisi WHERE IN\n$nsm_in_clause = \"'\" . implode(\"','\", $nsm_array) . \"'\";\n\n// Bangun query UPDATE\n$sql = \"\n    UPDATE daftar \n    SET no_agenda_kanwil = '', \n        status = 'sedang diproses' \n    WHERE tahun = '\" . db_addslashes($tahun) . \"'\n      AND nsm IN (\" . $nsm_in_clause . \")\n\";\n\n// Debug (opsional)\necho \"SQL: $sql<br>\";\n\n// Eksekusi query\nDB::Exec($sql);"
		}
	],
